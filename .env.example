# Your Search Atlas API key (from the Search Atlas dashboard)
SEARCHATLAS_API_KEY=your_api_key_here

# Optional: protect the /mcp endpoint with a bearer token
# If set, callers must send: Authorization: Bearer <token>
# Leave unset for an open (unauthenticated) endpoint
MCP_AUTH_TOKEN=

# Port (Railway sets this automatically)
PORT=3000
